{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django (server only)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver"],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Edge (browser only)",
      "type": "msedge",
      "request": "launch",
      "url": "http://127.0.0.1:8000/",
      "postDebugTask": "kill-django"
    }
  ],
  "compounds": [
    {
      "name": "▶ Django + Browser (F5)",
      "configurations": ["Django (server only)", "Edge (browser only)"],
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}
